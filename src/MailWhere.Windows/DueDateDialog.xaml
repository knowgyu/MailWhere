<Window x:Class="MailWhere.Windows.DueDateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="기한 설정" Height="230" Width="360" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="#F5F7FB" Icon="Assets/app-icon.ico">
    <Border Margin="18" CornerRadius="18" Background="#FFFFFF" Padding="18" BorderBrush="#E3E8F2" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="기한을 선택하세요" FontSize="18" FontWeight="Bold" Foreground="#14213D"/>
            <TextBlock x:Name="DescriptionText" Text="오늘 날짜를 기준으로 열립니다." Foreground="#667085" Margin="0,4,0,16"/>
            <DatePicker x:Name="DueDatePicker" SelectedDateFormat="Short" Margin="0,0,0,18"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Padding="14,8" Margin="0,0,8,0" IsCancel="True" Click="Cancel_Click">취소(Esc)</Button>
                <Button Padding="14,8" Background="#2458F2" Foreground="White" IsDefault="True" Click="Save_Click">저장(Enter)</Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
