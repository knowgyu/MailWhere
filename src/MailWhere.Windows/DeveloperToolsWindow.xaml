<Window x:Class="MailWhere.Windows.DeveloperToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="개발자 도구" Height="520" Width="620" MinHeight="420" MinWidth="560"
        WindowStartupLocation="CenterOwner" Background="{StaticResource MwBrush.Page}" Icon="Assets/app-icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource MwButton.Base}">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="MinHeight" Value="36"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MwBrush.Text}"/>
        </Style>
        <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource MwPanelBorder}">
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="20" Background="{StaticResource MwBrush.Surface}" Padding="18" Margin="0,0,0,12" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="개발자 도구" FontSize="22" FontWeight="Bold" Foreground="{StaticResource MwBrush.TextStrong}"/>
                <TextBlock x:Name="StatusText" Text="화면과 알림을 빠르게 확인합니다." Margin="0,5,0,0" Foreground="{StaticResource MwBrush.TextMuted}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="화면 테스트" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <Button Click="OpenToday_Click" Style="{StaticResource MwButton.Primary}">오늘 열기</Button>
                            <Button Click="OpenWeek_Click">이번 주 열기</Button>
                            <Button Click="OpenNoDue_Click">날짜 없음 열기</Button>
                            <Button Click="OpenAll_Click">전체 열기</Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="알림 테스트" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Button Click="Toast_Click" Style="{StaticResource MwButton.Primary}" HorizontalAlignment="Left">알림 보내기</Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="샘플 데이터" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <Button Click="SampleTasks_Click">샘플 업무 추가</Button>
                            <Button Click="SampleReview_Click">샘플 검토 후보 추가</Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="오늘 업무 자동 표시" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Button Click="ResetTodayMarker_Click" HorizontalAlignment="Left">오늘 표시 기록 초기화</Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" CornerRadius="18" Background="{StaticResource MwBrush.Surface}" Padding="12" Margin="0,12,0,0" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
            <Button Click="Close_Click" HorizontalAlignment="Right" IsCancel="True">닫기(Esc)</Button>
        </Border>
    </Grid>
</Window>
