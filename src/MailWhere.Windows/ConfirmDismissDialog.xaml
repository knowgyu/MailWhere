<Window x:Class="MailWhere.Windows.ConfirmDismissDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="업무보드에서 삭제" Height="245" Width="430" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="#F5F7FB" Icon="Assets/app-icon.ico">
    <Border Margin="18" CornerRadius="18" Background="#FFFFFF" Padding="18" BorderBrush="#E3E8F2" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="업무보드에서만 삭제할까요?" FontSize="18" FontWeight="Bold" Foreground="#14213D"/>
            <TextBlock Text="Outlook 원본 메일은 삭제하거나 수정하지 않습니다. MailWhere 목록에서만 숨깁니다." TextWrapping="Wrap" Foreground="#667085" Margin="0,6,0,16"/>
            <CheckBox x:Name="DoNotAskAgainBox" Content="다시 묻지 않기" Margin="0,0,0,18"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Padding="14,8" Margin="0,0,8,0" Click="Cancel_Click">취소</Button>
                <Button Padding="14,8" Background="#D92D20" Foreground="White" Click="Confirm_Click">삭제</Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
