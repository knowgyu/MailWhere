<Window x:Class="MailWhere.Windows.DailyBoardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="오늘의 업무 보드" Height="720" Width="1040" MinHeight="620" MinWidth="900"
        Icon="Assets/app-icon.ico" Background="#F5F7FB" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#20304F"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="#EEF3FF"/>
            <Setter Property="BorderBrush" Value="#D8E2FF"/>
            <Setter Property="Foreground" Value="#2458F2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CardList" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                    <Button Content="{Binding DueButtonText}" Visibility="{Binding DueButtonVisibility}" Tag="{Binding}" Click="SetDue_Click" Padding="9,5" Margin="0,0,6,0"/>
                                    <Button Content="열기" IsEnabled="{Binding CanOpen}" Tag="{Binding}" Click="OpenTask_Click" Padding="9,5" Margin="0,0,6,0"/>
                                    <Button Content="삭제" IsEnabled="{Binding HasTask}" Tag="{Binding}" Click="DismissTask_Click" Padding="9,5" Background="#FFF1F0" BorderBrush="#FDA29B" Foreground="#B42318"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                            <TextBlock Grid.Row="1" Text="{Binding Meta}" Foreground="#667085" FontSize="12" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="#F8FAFF"/>
            <Setter Property="BorderBrush" Value="#E8EDF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#EEF3FF"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#2458F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="22" Background="#FFFFFF" Padding="18" Margin="0,0,0,14" BorderBrush="#E3E8F2" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="오늘의 업무 보드" FontSize="24" FontWeight="Bold" Foreground="#14213D"/>
                    <TextBlock x:Name="SubtitleText" Text="오늘 챙길 할 일과 일정을 메일 기반으로 정리합니다." Margin="0,5,0,0" Foreground="#5F6B83"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="AddManualTask_Click" Background="#2458F2" Foreground="White" Margin="0,0,8,0">+ 직접 추가</Button>
                    <Border CornerRadius="14" Background="#EEF3FF" Padding="12,8">
                        <TextBlock x:Name="SummaryText" Text="요약 계산 중" FontWeight="SemiBold" Foreground="#2458F2"/>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="1">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                <Button x:Name="TodayFilterButton" Style="{StaticResource PillButton}" Click="TodayFilter_Click">오늘</Button>
                <Button x:Name="WeekFilterButton" Style="{StaticResource PillButton}" Click="WeekFilter_Click">7일 내</Button>
                <Button x:Name="MonthFilterButton" Style="{StaticResource PillButton}" Click="MonthFilter_Click">30일 내</Button>
                <Button x:Name="NoDueFilterButton" Style="{StaticResource PillButton}" Click="NoDueFilter_Click">기한 미정</Button>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="18" Background="#FFFFFF" Padding="16" Margin="0,0,8,0" BorderBrush="#E3E8F2" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="할 일" FontSize="19" FontWeight="Bold"/>
                            <TextBlock Text="회신, 제출, 확인, 검토처럼 내가 처리할 항목입니다." Foreground="#667085" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <ListBox x:Name="ActionList" Style="{StaticResource CardList}"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="18" Background="#FFFFFF" Padding="16" Margin="8,0,0,0" BorderBrush="#E3E8F2" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="일정" FontSize="19" FontWeight="Bold"/>
                            <TextBlock Text="회의, 참석, 발표, 캘린더성 일정입니다. 참조 메일이어도 표시합니다." Foreground="#667085" FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <ListBox x:Name="ScheduleList" Style="{StaticResource CardList}"/>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock x:Name="FooterText" DockPanel.Dock="Left" Text="삭제는 MailWhere 업무보드에서만 숨깁니다." Foreground="#667085" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Click="Close_Click" Background="#14213D" Foreground="White">확인</Button>
        </DockPanel>
    </Grid>
</Window>
