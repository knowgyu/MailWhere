<Window x:Class="MailWhere.Windows.DailyBoardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MailWhere 업무 보드" Height="740" Width="1120" MinHeight="640" MinWidth="980"
        Icon="Assets/app-icon.ico" Background="{StaticResource MwBrush.Page}" WindowStartupLocation="CenterScreen"
        PreviewKeyDown="DailyBoardWindow_PreviewKeyDown">
    <Window.Resources>
        <!-- Window-local implicit styles are limited to the 업무 보드 card/list surface;
             shared app-wide primitives remain keyed dictionaries merged from App.xaml. -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MwBrush.Text}"/>
        </Style>
        <Style x:Key="PillButton" TargetType="Button" BasedOn="{StaticResource MwSegmentedButton}">
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style x:Key="CardList" TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Title}" FontWeight="Bold" FontSize="15" TextWrapping="Wrap" MaxHeight="44"/>
                            <WrapPanel Grid.Row="1" Margin="0,7,0,0" VerticalAlignment="Center">
                                <Button Content="{Binding DueText}" Visibility="{Binding DueButtonVisibility}" Tag="{Binding}" Click="SetDue_Click" Style="{StaticResource MwButton.Ghost}" Margin="0,0,8,4" Padding="8,4"/>
                                <TextBlock Text="{Binding Meta}" Foreground="#667085" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </WrapPanel>
                            <WrapPanel Grid.Row="2" Margin="0,10,0,0" HorizontalAlignment="Right">
                                <Button Content="열기" IsEnabled="{Binding CanOpen}" Tag="{Binding}" Click="OpenTask_Click" Style="{StaticResource MwButton.Base}" Margin="0,0,6,6"/>
                                <Button Content="나중에" ToolTip="지정한 시간까지 잠시 보이지 않게 합니다." IsEnabled="{Binding HasTask}" Tag="{Binding}" Click="MoreActions_Click" Style="{StaticResource MwButton.Ghost}" Margin="0,0,6,6"/>
                                <Button Content="보관" ToolTip="목록에서 제외하고 다시 표시하지 않습니다." IsEnabled="{Binding HasTask}" Tag="{Binding}" Click="ArchiveTask_Click" Style="{StaticResource MwButton.Danger}" Margin="0,0,0,6"/>
                            </WrapPanel>
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="{StaticResource MwBrush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource MwBrush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#EEF3FF"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#2458F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="22" Background="{StaticResource MwBrush.Surface}" Padding="18" Margin="0,0,0,14" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="TitleText" Text="업무 보드" FontSize="24" FontWeight="Bold" Foreground="{StaticResource MwBrush.TextStrong}"/>
                    <TextBlock x:Name="SubtitleText" Text="메일에서 만든 업무를 한 목록으로 봅니다." Margin="0,5,0,0" Foreground="{StaticResource MwBrush.TextMuted}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="BoardStatusText" Visibility="Collapsed" Foreground="{StaticResource MwBrush.TextMuted}" VerticalAlignment="Center" Margin="0,0,12,0" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                    <Border CornerRadius="14" Background="#F8FAFC" Padding="12,8" Margin="0,0,8,0">
                        <TextBlock x:Name="UpdatedAtText" Text="방금 갱신" FontWeight="SemiBold" Foreground="#475467"/>
                    </Border>
                    <Button x:Name="ReviewCandidatesButton" Click="ReviewCandidates_Click" Visibility="Collapsed" Style="{StaticResource MwButton.Secondary}" Margin="0,0,8,0">검토 후보 보기</Button>
                    <Border CornerRadius="14" Background="{StaticResource MwBrush.PrimarySoft}" Padding="12,8" Margin="0,0,8,0">
                        <TextBlock x:Name="SummaryText" Text="요약 계산 중" FontWeight="SemiBold" Foreground="{StaticResource MwBrush.Primary}"/>
                    </Border>
                    <Button Click="AddManualTask_Click" Style="{StaticResource MwButton.Primary}" Margin="0">+ 직접 추가</Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="1">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <Border x:Name="BriefSummaryPanel" CornerRadius="18" Background="{StaticResource MwBrush.SurfaceMuted}" Padding="16" Margin="0,0,0,12" BorderBrush="{StaticResource MwBrush.BorderStrong}" BorderThickness="1" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="오늘 브리핑" FontSize="18" FontWeight="Bold" Foreground="{StaticResource MwBrush.TextStrong}"/>
                            <TextBlock x:Name="BriefSummaryBodyText" Text="요약 계산 중" Margin="0,5,0,0" Foreground="{StaticResource MwBrush.Primary}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="BriefSummaryMetaText" Text="업무 보드에서 계속 관리합니다." Margin="0,4,0,0" Foreground="{StaticResource MwBrush.TextMuted}"/>
                        </StackPanel>
                        <Button x:Name="BriefReviewCandidatesButton" Grid.Column="1" Click="ReviewCandidates_Click" Style="{StaticResource MwButton.Secondary}" VerticalAlignment="Center">검토 후보 보기</Button>
                    </Grid>
                </Border>
                <Border x:Name="FilterPanel" CornerRadius="16" Background="{StaticResource MwBrush.PrimarySoft}" Padding="4" BorderBrush="{StaticResource MwBrush.BorderStrong}" BorderThickness="1">
                    <UniformGrid Rows="1" Columns="5">
                        <Button x:Name="AllFilterButton" Style="{StaticResource PillButton}" Click="AllFilter_Click">전체</Button>
                        <Button x:Name="TodayFilterButton" Style="{StaticResource PillButton}" Click="TodayFilter_Click">오늘</Button>
                        <Button x:Name="WeekFilterButton" Style="{StaticResource PillButton}" Click="WeekFilter_Click">7일 내</Button>
                        <Button x:Name="MonthFilterButton" Style="{StaticResource PillButton}" Click="MonthFilter_Click">30일 내</Button>
                        <Button x:Name="NoDueFilterButton" Style="{StaticResource PillButton}" Click="NoDueFilter_Click">기한 미정</Button>
                    </UniformGrid>
                </Border>
            </StackPanel>

            <Grid>
                <Border x:Name="BoardListPanel" CornerRadius="18" Background="{StaticResource MwBrush.Surface}" Padding="16" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="업무" FontSize="19" FontWeight="Bold"/>
                        </StackPanel>
                        <ListBox x:Name="TaskList" Style="{StaticResource CardList}" MouseDoubleClick="BoardCard_MouseDoubleClick"/>
                    </DockPanel>
                </Border>
                <TextBlock x:Name="BoardEmptyText" Text="표시할 업무가 없습니다." Visibility="Collapsed" Foreground="{StaticResource MwBrush.TextMuted}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
