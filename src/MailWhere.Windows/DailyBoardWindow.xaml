<Window x:Class="MailWhere.Windows.DailyBoardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="오늘의 업무 보드" Height="680" Width="900" MinHeight="560" MinWidth="760"
        Icon="Assets/app-icon.ico" Background="#F5F7FB" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#20304F"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" LineHeight="19"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="#F8FAFF"/>
            <Setter Property="BorderBrush" Value="#E8EDF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#EEF3FF"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#2458F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="22" Background="#FFFFFF" Padding="18" Margin="0,0,0,14" BorderBrush="#E3E8F2" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="오늘의 업무 보드" FontSize="24" FontWeight="Bold" Foreground="#14213D"/>
                    <TextBlock x:Name="SubtitleText" Text="오늘 챙길 메일 기반 후속조치를 한 번에 봅니다." Margin="0,5,0,0" Foreground="#5F6B83"/>
                </StackPanel>
                <Border DockPanel.Dock="Right" CornerRadius="14" Background="#EEF3FF" Padding="12,8">
                    <TextBlock x:Name="SummaryText" Text="요약 계산 중" FontWeight="SemiBold" Foreground="#2458F2"/>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Grid.Row="0" CornerRadius="18" Background="#FFFFFF" Padding="14" Margin="0,0,12,12" BorderBrush="#E3E8F2" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="오늘 / 지남" FontSize="17" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ListBox x:Name="DueTodayList" MouseDoubleClick="OpenSelectedMail_DoubleClick"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Grid.Row="0" CornerRadius="18" Background="#FFFFFF" Padding="14" Margin="0,0,0,12" BorderBrush="#E3E8F2" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="앞으로 7일" FontSize="17" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ListBox x:Name="UpcomingList" MouseDoubleClick="OpenSelectedMail_DoubleClick"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="0" Grid.Row="1" CornerRadius="18" Background="#FFFFFF" Padding="14" Margin="0,0,12,0" BorderBrush="#E3E8F2" BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="마감 없음" FontSize="17" FontWeight="Bold" Margin="0,0,0,8"/>
                    <ListBox x:Name="NoDueList" MouseDoubleClick="OpenSelectedMail_DoubleClick"/>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Grid.Row="1" CornerRadius="18" Background="#FFFFFF" Padding="14" BorderBrush="#E3E8F2" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="확인 필요" FontSize="17" FontWeight="Bold"/>
                        <TextBlock Text="애매한 후보는 팝업으로 쏟아내지 않고 보드/검토함에 모읍니다. 필요할 때 MailWhere 검토함에서 등록하거나 무시하세요." TextWrapping="Wrap" Foreground="#667085" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ListBox x:Name="ReviewList" MouseDoubleClick="OpenSelectedMail_DoubleClick"/>
                </DockPanel>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock DockPanel.Dock="Left" Text="더블클릭하면 가능한 경우 Outlook 원본 메일을 엽니다." Foreground="#667085" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="OpenReview_Click" Margin="0,0,8,0">검토함 열기</Button>
                <Button Click="Close_Click" Background="#14213D" Foreground="White">확인</Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
