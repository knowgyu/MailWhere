<Window x:Class="MailWhere.Windows.ToastNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MailWhere 알림"
        Width="420"
        SizeToContent="Height"
        Icon="Assets/app-icon.ico"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False">
    <Window.Resources>
        <Style x:Key="ToastButton" TargetType="Button" BasedOn="{StaticResource MwToastButton}"/>
    </Window.Resources>

    <Grid Margin="10">
        <Border x:Name="ToastCard"
                CornerRadius="16"
                Background="#FFFFFF"
                BorderBrush="#D8E0F0"
                BorderThickness="1"
                SnapsToDevicePixels="True"
                MouseLeftButtonUp="ToastCard_MouseLeftButtonUp">
            <Border.Effect>
                <DropShadowEffect Color="#0F172A" BlurRadius="18" ShadowDepth="4" Opacity="0.16"/>
            </Border.Effect>

            <Grid Margin="18,16,14,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="KindText"
                               Text="MailWhere"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#475467"
                               TextTrimming="CharacterEllipsis"/>

                    <Button Grid.Column="1"
                            x:Name="CloseButton"
                            Click="CloseButton_Click"
                            Width="26"
                            Height="26"
                            Padding="0"
                            Background="Transparent"
                            Foreground="#667085"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="닫기">×</Button>
                </Grid>

                <TextBlock x:Name="TitleText"
                           Grid.Row="1"
                           Text="알림 제목"
                           Margin="0,3,28,0"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#101828"
                           TextWrapping="Wrap"
                           MaxHeight="44"/>

                <StackPanel Grid.Row="2" Margin="0,8,0,0">
                    <TextBlock x:Name="MessageText"
                               Text="알림 내용"
                               Foreground="#475467"
                               FontSize="13"
                               TextWrapping="Wrap"
                               MaxHeight="64"/>
                    <TextBlock x:Name="MetaText"
                               Text="클릭해서 확인"
                               Margin="0,7,0,0"
                               Foreground="#667085"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Left">
                    <Button x:Name="PrimaryButton"
                            Style="{StaticResource ToastButton}"
                            Click="PrimaryButton_Click"
                            Background="{StaticResource MwBrush.Primary}"
                            Foreground="White">업무 보드</Button>
                    <Button x:Name="SecondaryButton"
                            Style="{StaticResource ToastButton}"
                            Click="SecondaryButton_Click"
                            Background="{StaticResource MwBrush.PrimarySoft}"
                            Foreground="#344054">검토 후보</Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
