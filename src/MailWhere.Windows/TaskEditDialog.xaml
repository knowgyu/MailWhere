<Window x:Class="MailWhere.Windows.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="업무 수정" Height="360" Width="430" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="#F5F7FB" Icon="Assets/app-icon.ico">
    <Border Margin="18" CornerRadius="18" Background="#FFFFFF" Padding="18" BorderBrush="#E3E8F2" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="업무 내용을 바로잡기" FontSize="18" FontWeight="Bold" Foreground="#14213D"/>
            <TextBlock Text="AI가 만든 제목, 유형, 기한을 짧게 수정합니다." Foreground="#667085" Margin="0,4,0,16" TextWrapping="Wrap"/>

            <TextBlock Text="제목" FontWeight="SemiBold" Foreground="#14213D"/>
            <TextBox x:Name="TitleText" Margin="0,4,0,12" Padding="8,6" MinHeight="34"/>

            <TextBlock Text="유형" FontWeight="SemiBold" Foreground="#14213D"/>
            <ComboBox x:Name="KindBox" Margin="0,4,0,12" Padding="8,6" MinHeight="34" DisplayMemberPath="Label"/>

            <TextBlock Text="기한" FontWeight="SemiBold" Foreground="#14213D"/>
            <DockPanel Margin="0,4,0,10">
                <CheckBox x:Name="NoDueCheck" DockPanel.Dock="Right" Content="기한 없음" VerticalAlignment="Center" Margin="12,0,0,0" Click="NoDue_Click"/>
                <DatePicker x:Name="DueDatePicker" SelectedDateFormat="Short"/>
            </DockPanel>
            <TextBlock x:Name="ErrorText" Visibility="Collapsed" Foreground="#C62828" Margin="0,0,0,10" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Padding="14,8" Margin="0,0,8,0" Click="Cancel_Click">취소</Button>
                <Button Padding="14,8" Background="#2458F2" Foreground="White" Click="Save_Click">저장</Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
