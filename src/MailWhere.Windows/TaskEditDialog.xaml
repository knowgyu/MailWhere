<Window x:Class="MailWhere.Windows.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="업무 수정" Height="310" Width="520" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource MwBrush.Page}" Icon="Assets/app-icon.ico">
    <Border Margin="18" CornerRadius="20" Background="{StaticResource MwBrush.Surface}" Padding="22" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="업무 수정" FontSize="20" FontWeight="Bold" Foreground="{StaticResource MwBrush.TextStrong}"/>
                <TextBlock Text="제목과 기한만 바로잡습니다." Foreground="{StaticResource MwBrush.TextMuted}" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <TextBlock Text="제목" FontWeight="SemiBold" Foreground="{StaticResource MwBrush.TextStrong}"/>
                <TextBox x:Name="TitleText" Margin="0,6,0,0" Padding="10,8" MinHeight="38"/>
            </StackPanel>

            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="기한" FontWeight="SemiBold" Foreground="{StaticResource MwBrush.TextStrong}"/>
                    <DatePicker x:Name="DueDatePicker" Margin="0,6,12,0" MinHeight="36" SelectedDateFormat="Short"/>
                </StackPanel>
                <CheckBox x:Name="NoDueCheck" Grid.Column="1" Content="기한 없음" VerticalAlignment="Bottom" Margin="12,0,0,8" Click="NoDue_Click"/>
            </Grid>

            <TextBlock x:Name="ErrorText" Grid.Row="3" Visibility="Collapsed" Foreground="#C62828" TextWrapping="Wrap"/>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Padding="16,8" Margin="0,0,8,0" Click="Cancel_Click">취소</Button>
                <Button Padding="16,8" Background="#2458F2" Foreground="White" Click="Save_Click">저장</Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
