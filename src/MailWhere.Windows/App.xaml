<Application x:Class="MailWhere.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Theme.Brushes.xaml"/>
                <ResourceDictionary Source="Resources/Theme.Typography.xaml"/>
                <ResourceDictionary Source="Resources/Theme.Spacing.xaml"/>
                <ResourceDictionary Source="Resources/Controls.Buttons.xaml"/>
                <ResourceDictionary Source="Resources/Controls.Segmented.xaml"/>
                <ResourceDictionary Source="Resources/Controls.Cards.xaml"/>
                <ResourceDictionary Source="Resources/Controls.Toast.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
