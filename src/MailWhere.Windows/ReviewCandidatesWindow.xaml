<Window x:Class="MailWhere.Windows.ReviewCandidatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="검토 후보" Height="560" Width="900" MinHeight="420" MinWidth="760"
        WindowStartupLocation="CenterOwner" Background="{StaticResource MwBrush.Page}" Icon="Assets/app-icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource MwButton.Base}">
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MwBrush.Text}"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MwCardListBoxItem}">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="{StaticResource MwBrush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource MwBrush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="20" Background="{StaticResource MwBrush.Surface}" Padding="18" Margin="0,0,0,12" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
            <DockPanel>
                <Button DockPanel.Dock="Right" Click="Close_Click" Style="{StaticResource MwButton.Ghost}" Margin="12,0,0,0">닫기(Esc)</Button>
                <StackPanel>
                    <TextBlock Text="검토 후보" FontSize="22" FontWeight="Bold" Foreground="{StaticResource MwBrush.TextStrong}"/>
                    <TextBlock x:Name="StatusText" Text="필요한 항목만 업무에 올립니다." Margin="0,5,0,0" Foreground="{StaticResource MwBrush.TextMuted}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" CornerRadius="18" Background="{StaticResource MwBrush.Surface}" Padding="14" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
            <Grid>
                <ListBox x:Name="CandidatesList" MouseDoubleClick="CandidatesList_DoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="58">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="300"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Meta}" Foreground="{StaticResource MwBrush.TextMuted}" FontSize="13" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="18,0,0,0">
                                    <Button Content="등록" Tag="{Binding}" Click="Approve_Click" Style="{StaticResource MwButton.Primary}" Margin="0,0,6,0"/>
                                    <Button Content="원본 열기" IsEnabled="{Binding CanOpen}" Tag="{Binding}" Click="OpenMail_Click" Margin="0,0,6,0"/>
                                    <Button Content="나중에" Tag="{Binding}" Click="Snooze_Click" Style="{StaticResource MwButton.Ghost}" Margin="0,0,6,0"/>
                                    <Button Content="무시" Tag="{Binding}" Click="Ignore_Click" Style="{StaticResource MwButton.Danger}" Margin="0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock x:Name="EmptyText" Text="표시할 검토 후보가 없습니다." Visibility="Collapsed" Foreground="{StaticResource MwBrush.TextMuted}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
