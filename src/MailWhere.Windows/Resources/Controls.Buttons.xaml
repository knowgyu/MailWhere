<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="MwButton.Base" TargetType="Button">
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource MwBrush.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MwBrush.BorderStrong}"/>
        <Setter Property="Foreground" Value="{StaticResource MwBrush.Text}"/>
    </Style>
    <Style x:Key="MwButton.Primary" TargetType="Button" BasedOn="{StaticResource MwButton.Base}">
        <Setter Property="Background" Value="{StaticResource MwBrush.Primary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MwBrush.Primary}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style x:Key="MwButton.Secondary" TargetType="Button" BasedOn="{StaticResource MwButton.Base}">
        <Setter Property="Background" Value="{StaticResource MwBrush.PrimarySoft}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MwBrush.BorderStrong}"/>
        <Setter Property="Foreground" Value="{StaticResource MwBrush.Primary}"/>
    </Style>
    <Style x:Key="MwButton.Success" TargetType="Button" BasedOn="{StaticResource MwButton.Base}">
        <Setter Property="Background" Value="{StaticResource MwBrush.SuccessSoft}"/>
        <Setter Property="BorderBrush" Value="#ABEFC6"/>
        <Setter Property="Foreground" Value="{StaticResource MwBrush.Success}"/>
    </Style>
    <Style x:Key="MwButton.Danger" TargetType="Button" BasedOn="{StaticResource MwButton.Base}">
        <Setter Property="Background" Value="{StaticResource MwBrush.DangerSoft}"/>
        <Setter Property="BorderBrush" Value="#FDA29B"/>
        <Setter Property="Foreground" Value="{StaticResource MwBrush.Danger}"/>
    </Style>
    <Style x:Key="MwButton.Ghost" TargetType="Button" BasedOn="{StaticResource MwButton.Base}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource MwBrush.TextMuted}"/>
    </Style>
</ResourceDictionary>
