<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="MwPanelBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Background" Value="{StaticResource MwBrush.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MwBrush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="16"/>
    </Style>
    <Style x:Key="MwCardListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
        <Setter Property="Background" Value="{StaticResource MwBrush.SurfaceMuted}"/>
        <Setter Property="BorderBrush" Value="{StaticResource MwBrush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
</ResourceDictionary>
