<Window x:Class="MailWhere.Windows.ReviewCandidateToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="확인 필요 후보" Height="230" Width="420"
        Icon="Assets/app-icon.ico" Background="Transparent" AllowsTransparency="True"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True"
        Focusable="True" ShowActivated="False">
    <Border CornerRadius="18" Background="#FFFFFF" Padding="16" BorderBrush="#C7D2FE" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#334155" BlurRadius="22" ShadowDepth="5" Opacity="0.25"/>
        </Border.Effect>
        <DockPanel LastChildFill="False">
            <StackPanel DockPanel.Dock="Top">
                <TextBlock Text="확인 필요 후보" FontSize="16" FontWeight="Bold" Foreground="#14213D"/>
                <TextBlock x:Name="TitleText" Text="후보 제목" Margin="0,6,0,0" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#20304F"/>
                <TextBlock x:Name="ReasonText" Text="판단 이유" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#667085"/>
                <TextBlock x:Name="EvidenceText" Text="" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="#667085" FontSize="12"/>
            </StackPanel>

            <DockPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                <TextBlock DockPanel.Dock="Left" Text="팝업 클릭 후 Ctrl+Y 등록 · Ctrl+N 무시" Foreground="#2458F2" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="Approve_Click" Padding="10,6" Margin="0,0,8,0" Background="#2458F2" Foreground="White" FontWeight="SemiBold">등록</Button>
                    <Button Click="Ignore_Click" Padding="10,6" Background="#EEF2F7" Foreground="#334155" FontWeight="SemiBold">무시</Button>
                </StackPanel>
            </DockPanel>
        </DockPanel>
    </Border>
</Window>
