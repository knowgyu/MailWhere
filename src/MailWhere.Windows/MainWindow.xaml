<Window x:Class="MailWhere.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MailWhere" Height="720" Width="1100" MinHeight="640" MinWidth="980"
        Icon="Assets/app-icon.ico" Background="{StaticResource MwBrush.Page}"
        KeyDown="MainWindow_KeyDown">
    <Window.Resources>
        <!-- Window-local implicit styles intentionally scope shell form/list rhythm to MainWindow only.
             App.xaml keeps broad resources keyed to avoid accidental app-wide restyling. -->
        <Style TargetType="Button" BasedOn="{StaticResource MwButton.Base}">
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,12,12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,12,12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="34"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MwBrush.Text}"/>
        </Style>
        <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource MwPanelBorder}">
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" LineHeight="19"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MwCardListBoxItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource MwBrush.PrimarySoft}"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource MwBrush.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="22" Background="{StaticResource MwBrush.Surface}" Padding="18" Margin="0,0,0,14" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="MailWhere" FontSize="24" FontWeight="Bold" Foreground="{StaticResource MwBrush.TextStrong}"/>
                    <TextBlock Text="트레이에서 조용히 지켜보고, 필요한 순간 업무 보드와 오늘 브리핑으로 이어집니다." Margin="0,5,0,0" Foreground="{StaticResource MwBrush.TextMuted}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="OpenDailyBoard_Click" Style="{StaticResource MwButton.Secondary}">업무 보드</Button>
                    <Button x:Name="ScanRecentMonthButton" Click="ScanRecentMonth_Click" Style="{StaticResource MwButton.Primary}">최근 1개월 스캔</Button>
                    <Button x:Name="StopScanButton" Click="StopScan_Click" Visibility="Collapsed" Style="{StaticResource MwButton.Danger}">스캔 중지</Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" CornerRadius="20" Background="{StaticResource MwBrush.Surface}" Padding="16" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="오늘 업무" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="StatusText" Text="대기 중입니다. 최근 1개월 스캔을 실행하면 내가 할 일과 기다리는 일을 모아줍니다." Foreground="{StaticResource MwBrush.TextMuted}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <ProgressBar x:Name="ScanProgressBar" Height="4" IsIndeterminate="True" Visibility="Collapsed" Margin="0,10,0,4"/>
                        <TextBlock x:Name="ScanProgressText" Text="대기 중입니다." Visibility="Collapsed" Foreground="{StaticResource MwBrush.Primary}" FontWeight="SemiBold" FontSize="12"/>
                    </StackPanel>
                    <Border Grid.Column="1" CornerRadius="14" Background="{StaticResource MwBrush.PrimarySoft}" Padding="12,8" VerticalAlignment="Top" Margin="16,0,0,0">
                        <TextBlock Text="설정은 탭 안에 정리했습니다" Foreground="{StaticResource MwBrush.Primary}" FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <TabControl x:Name="MainTabs">
                    <TabItem x:Name="TasksTab" Header="업무 보드">
                        <DockPanel Margin="8">
                            <Border DockPanel.Dock="Top" Style="{StaticResource SectionCard}">
                                <StackPanel>
                                    <TextBlock Text="빠른 할 일 추가" FontWeight="SemiBold"/>
                                    <Grid Margin="0,6,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ManualTaskText" Grid.Column="0" ToolTip="예: 금요일까지 리뷰 자료 공유"/>
                                        <TextBox x:Name="ManualDueText" Grid.Column="1" ToolTip="예: 내일, 금요일, 2026-05-20" />
                                        <Button Grid.Column="2" Click="AddManualTask_Click" Style="{StaticResource MwButton.Primary}">추가</Button>
                                    </Grid>
                                    <TextBlock Text="마감은 비워둘 수 있습니다. '내일', '금요일', '2026-05-20'을 우선 지원합니다." Foreground="{StaticResource MwBrush.TextMuted}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <ListBox x:Name="TasksList" FontSize="14">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel Grid.Row="0" LastChildFill="True">
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                                                    <Button Content="{Binding DueButtonText}" Visibility="{Binding DueButtonVisibility}" IsEnabled="{Binding HasTask}" Tag="{Binding}" Click="SetTaskDueButton_Click" Style="{StaticResource MwButton.Secondary}" Margin="0,0,6,0"/>
                                                    <Button Content="열기" IsEnabled="{Binding CanOpen}" Tag="{Binding}" Click="OpenTaskButton_Click" Style="{StaticResource MwButton.Base}" Margin="0,0,6,0"/>
                                                    <Button Content="숨김" IsEnabled="{Binding HasTask}" Tag="{Binding}" Click="DismissTaskButton_Click" Style="{StaticResource MwButton.Danger}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding Meta}" Foreground="{StaticResource MwBrush.TextMuted}" FontSize="12" Margin="0,5,0,0" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <TabItem x:Name="ReviewTab" Header="검토 후보">
                        <DockPanel Margin="8">
                            <Border DockPanel.Dock="Top" Style="{StaticResource SectionCard}">
                                <StackPanel>
                                    <TextBlock Text="검토 후보" FontWeight="SemiBold"/>
                                    <TextBlock Text="확신이 낮아 자동 등록하지 않은 후보입니다. 필요한 항목만 골라 업무 보드에 올리세요." TextWrapping="Wrap" Foreground="{StaticResource MwBrush.TextMuted}" Margin="0,4,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Click="ApproveSelectedReview_Click" Style="{StaticResource MwButton.Primary}">등록 (Alt+A)</Button>
                                        <Button Click="OpenSelectedReviewMail_Click">원본 메일 열기</Button>
                                        <Button Click="SnoozeSelectedReview_Click">나중에 보기 (Alt+S)</Button>
                                        <Button Click="IgnoreSelectedReview_Click" Style="{StaticResource MwButton.Danger}">무시 (Alt+I)</Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ListBox x:Name="ReviewCandidatesList" FontSize="14" MouseDoubleClick="OpenSelectedReviewMail_DoubleClick"/>
                        </DockPanel>
                    </TabItem>

                    <TabItem x:Name="SettingsTab" Header="설정">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <Border Style="{StaticResource SectionCard}">
                                            <StackPanel>
                                                <TextBlock Text="일반" FontSize="16" FontWeight="Bold"/>
                                                <TextBlock Text="매일 쓰는 동작만 먼저 둡니다." Foreground="{StaticResource MwBrush.TextMuted}" Margin="0,4,0,12"/>
                                                <CheckBox x:Name="StartupToggle" Content="Windows 시작 시 실행" Click="StartupToggle_Click" Margin="0,0,0,10"/>
                                                <TextBlock Text="최근 스캔 기간(일)" FontWeight="SemiBold"/>
                                                <TextBox x:Name="ScanDaysText"/>
                                                <Button Click="SaveSettings_Click" HorizontalAlignment="Left" Style="{StaticResource MwButton.Primary}">설정 저장</Button>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SectionCard}">
                                            <StackPanel>
                                                <TextBlock Text="오늘 브리핑·알림" FontSize="16" FontWeight="Bold"/>
                                                <TextBlock Text="트레이 알림과 업무 보드 진입 시간을 조정합니다." Foreground="{StaticResource MwBrush.TextMuted}" Margin="0,4,0,12"/>
                                                <TextBlock Text="알림 미리 보기(시간)" FontWeight="SemiBold"/>
                                                <TextBox x:Name="ReminderLookAheadText"/>
                                                <TextBlock Text="오늘 브리핑 시간" FontWeight="SemiBold"/>
                                                <TextBox x:Name="DailyBoardTimeText" ToolTip="기본 08:00. 이 시간이 지난 뒤 앱이 켜지면 다음 정시에 한 번 알립니다."/>
                                                <TextBlock Text="시작 후 대기(분)" FontWeight="SemiBold"/>
                                                <TextBox x:Name="DailyBoardStartupDelayText" ToolTip="Windows 시작 직후 Outlook/LLM 등 다른 프로세스가 준비될 시간을 둡니다. 기본 10분."/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <Border Style="{StaticResource SectionCard}">
                                            <StackPanel>
                                                <TextBlock Text="LLM" FontSize="16" FontWeight="Bold"/>
                                                <TextBlock Text="연결된 endpoint가 있으면 메일 분석에 사용합니다. 토큰 값은 저장하지 않습니다." Foreground="{StaticResource MwBrush.TextMuted}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                                                <CheckBox x:Name="LlmEnabledToggle" Content="로컬 LLM 분석 사용" Click="LlmEnabledToggle_Click" Margin="0,0,0,10"/>
                                                <TextBlock Text="Endpoint 방식" FontWeight="SemiBold"/>
                                                <ComboBox x:Name="LlmProviderBox">
                                                    <ComboBoxItem Tag="OllamaNative" Content="Ollama 로컬"/>
                                                    <ComboBoxItem Tag="OpenAiChatCompletions" Content="OpenAI 호환 · Chat Completions"/>
                                                    <ComboBoxItem Tag="OpenAiResponses" Content="OpenAI 호환 · Responses"/>
                                                </ComboBox>
                                                <TextBlock Text="Endpoint" FontWeight="SemiBold"/>
                                                <TextBox x:Name="LlmEndpointText" ToolTip="예: http://localhost:11434 또는 http://localhost:8000"/>
                                                <TextBlock Text="모델" FontWeight="SemiBold"/>
                                                <Grid Margin="0,4,12,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="LlmModelBox" Grid.Column="0" IsEditable="True" Margin="0" ToolTip="모델을 불러오거나 직접 입력하세요."/>
                                                    <Button x:Name="LoadLlmModelsButton" Grid.Column="1" Click="LoadLlmModels_Click" Margin="8,0,0,0">모델 불러오기</Button>
                                                </Grid>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <Button x:Name="TestLlmEndpointButton" Click="TestLlmEndpoint_Click" Style="{StaticResource MwButton.Primary}">연결 테스트</Button>
                                                    <TextBlock x:Name="LlmStatusText" Text="LLM 연결 테스트 전입니다." VerticalAlignment="Center" Foreground="{StaticResource MwBrush.TextMuted}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SectionCard}">
                                            <StackPanel>
                                                <TextBlock Text="고급" FontSize="16" FontWeight="Bold"/>
                                                <CheckBox x:Name="AutoWatcherToggle" Content="자동 watcher 요청(운영 smoke gate 후 활성)" Margin="0,8,0,10"/>
                                                <TextBlock Text="최대 메일 수(비우면 최근 기간 전체)" FontWeight="SemiBold"/>
                                                <TextBox x:Name="MaxItemsText" ToolTip="문제 진단 때만 숫자를 넣으세요."/>
                                                <TextBlock Text="LLM timeout(초)" FontWeight="SemiBold"/>
                                                <TextBox x:Name="LlmTimeoutText" ToolTip="로컬 30B 이상 모델은 90~180초를 권장합니다."/>
                                                <TextBlock Text="Bearer token 환경 변수(선택)" FontWeight="SemiBold"/>
                                                <TextBox x:Name="LlmApiKeyEnvText" ToolTip="예: LOCAL_LLM_TOKEN. 토큰 값 자체는 앱 설정에 저장하지 마세요."/>
                                                <TextBlock Text="LLM 분석 실패 처리" FontWeight="SemiBold"/>
                                                <ComboBox x:Name="LlmFallbackPolicyBox">
                                                    <ComboBoxItem Tag="LlmOnly" Content="검토 후보로 보관"/>
                                                    <ComboBoxItem Tag="LlmThenRules" Content="규칙 기반 fallback 허용"/>
                                                </ComboBox>
                                                <TextBlock Text="기본값은 검토 후보 보관입니다. 규칙 fallback은 LLM 장애 중에도 후보를 만들고 싶을 때만 켜세요." Foreground="{StaticResource MwBrush.TextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,-6,12,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Text="문제 해결" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text="평소에는 열지 않아도 됩니다. Outlook/저장소/LLM 연결이 이상할 때만 확인하세요." Foreground="{StaticResource MwBrush.TextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Button Click="RunDiagnostics_Click">진단 실행</Button>
                                            <Button Click="TestNotification_Click">알림 테스트</Button>
                                            <Button Click="ResetLocalData_Click" Style="{StaticResource MwButton.Danger}">업무 데이터 초기화</Button>
                                        </StackPanel>
                                        <TextBlock Text="초기화는 테스트/개발용입니다. 저장된 할 일·검토 후보·스캔 중복 기록만 지우고 설정은 유지합니다." Foreground="{StaticResource MwBrush.TextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                        <TextBox x:Name="DiagnosticsText" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas" MinHeight="140" Text="진단을 실행하면 안전한 코드와 상태만 표시됩니다."/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>
    </Grid>
</Window>
