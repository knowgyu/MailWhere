<Window x:Class="MailWhere.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MailWhere" Height="720" Width="1120" MinHeight="620" MinWidth="980"
        Icon="Assets/app-icon.ico" Background="{StaticResource MwBrush.Page}"
        KeyDown="MainWindow_KeyDown">
    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource MwButton.Base}">
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MwBrush.Text}"/>
        </Style>
        <Style x:Key="BoardFilterButton" TargetType="Button" BasedOn="{StaticResource MwSegmentedButton}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinHeight" Value="38"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MwCardListBoxItem}">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Background" Value="{StaticResource MwBrush.SurfaceMuted}"/>
            <Setter Property="BorderBrush" Value="{StaticResource MwBrush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource MwBrush.PrimarySoft}"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource MwBrush.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="22" Background="{StaticResource MwBrush.Surface}" Padding="18" Margin="0,0,0,12" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="OpenReviewCandidatesButton" Click="OpenReviewCandidates_Click" Style="{StaticResource MwButton.Secondary}">검토 후보</Button>
                    <Button x:Name="OpenSettingsButton" Click="OpenSettings_Click" Style="{StaticResource MwButton.Secondary}">설정</Button>
                    <Button x:Name="OpenDeveloperToolsButton" Click="OpenDeveloperTools_Click" Style="{StaticResource MwButton.Ghost}">개발자 도구</Button>
                    <Button x:Name="AddManualHeaderButton" Click="AddManualTaskDialog_Click" Style="{StaticResource MwButton.Secondary}">+ 직접 추가</Button>
                    <Button x:Name="ScanRecentMonthButton" Click="ScanRecentMonth_Click" Style="{StaticResource MwButton.Primary}">지금 메일 확인</Button>
                    <Button x:Name="StopScanButton" Click="StopScan_Click" Visibility="Collapsed" Style="{StaticResource MwButton.Danger}">확인 중지</Button>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="MailWhere" FontSize="24" FontWeight="Bold" Foreground="{StaticResource MwBrush.TextStrong}"/>
                    <TextBlock x:Name="StatusText" Text="트레이에서 대기 중입니다." Margin="0,5,0,0" Foreground="{StaticResource MwBrush.TextMuted}" TextWrapping="Wrap"/>
                    <ProgressBar x:Name="ScanProgressBar" Height="4" IsIndeterminate="True" Visibility="Collapsed" Margin="0,10,12,4"/>
                    <TextBlock x:Name="ScanProgressText" Text="대기 중입니다." Visibility="Collapsed" Foreground="{StaticResource MwBrush.Primary}" FontWeight="SemiBold" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" x:Name="FilterPanel" CornerRadius="16" Background="{StaticResource MwBrush.PrimarySoft}" Padding="4" Margin="0,0,0,12" BorderBrush="{StaticResource MwBrush.BorderStrong}" BorderThickness="1">
            <UniformGrid Rows="1" Columns="4">
                <Button x:Name="TodayFilterButton" Style="{StaticResource BoardFilterButton}" Click="TodayMainFilter_Click">오늘</Button>
                <Button x:Name="WeekFilterButton" Style="{StaticResource BoardFilterButton}" Click="WeekMainFilter_Click">이번 주</Button>
                <Button x:Name="NoDueFilterButton" Style="{StaticResource BoardFilterButton}" Click="NoDueMainFilter_Click">날짜 없음</Button>
                <Button x:Name="AllFilterButton" Style="{StaticResource BoardFilterButton}" Click="AllMainFilter_Click">전체</Button>
            </UniformGrid>
        </Border>

        <Border Grid.Row="2" CornerRadius="20" Background="{StaticResource MwBrush.Surface}" Padding="14" BorderBrush="{StaticResource MwBrush.Border}" BorderThickness="1">
            <Grid>
                <ListBox x:Name="TasksList" FontSize="14" MouseDoubleClick="TaskList_DoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="300"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" ToolTip="{Binding Title}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Meta}" Foreground="{StaticResource MwBrush.TextMuted}" FontSize="13" VerticalAlignment="Center" Margin="18,0,18,0" TextTrimming="CharacterEllipsis" MaxWidth="340"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Button Content="열기" IsEnabled="{Binding CanOpen}" Tag="{Binding}" Click="OpenTaskButton_Click" Style="{StaticResource MwButton.Base}" Margin="0,0,6,0"/>
                                    <Button Content="나중에" IsEnabled="{Binding HasTask}" Tag="{Binding}" Click="SnoozeTaskButton_Click" Style="{StaticResource MwButton.Ghost}" Margin="0,0,6,0"/>
                                    <Button Content="보관" IsEnabled="{Binding HasTask}" Tag="{Binding}" Click="ArchiveTaskButton_Click" Style="{StaticResource MwButton.Danger}" Margin="0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock x:Name="TasksEmptyText" Text="표시할 업무가 없습니다." Visibility="Collapsed" Foreground="{StaticResource MwBrush.TextMuted}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Visibility="Collapsed" IsHitTestVisible="False">
            <TextBox x:Name="ManualTaskText"/>
            <TextBox x:Name="ManualDueText"/>
            <CheckBox x:Name="StartupToggle" Click="StartupToggle_Click"/>
            <CheckBox x:Name="AutoWatcherToggle"/>
            <CheckBox x:Name="LlmEnabledToggle" Click="LlmEnabledToggle_Click"/>
            <ComboBox x:Name="LlmProviderBox">
                <ComboBoxItem Tag="OllamaNative" Content="Ollama 로컬"/>
                <ComboBoxItem Tag="OpenAiChatCompletions" Content="OpenAI 호환 · Chat Completions"/>
                <ComboBoxItem Tag="OpenAiResponses" Content="OpenAI 호환 · Responses"/>
            </ComboBox>
            <TextBox x:Name="LlmEndpointText"/>
            <ComboBox x:Name="LlmModelBox" IsEditable="True"/>
            <Button x:Name="LoadLlmModelsButton" Click="LoadLlmModels_Click"/>
            <Button x:Name="TestLlmEndpointButton" Click="TestLlmEndpoint_Click"/>
            <TextBlock x:Name="LlmStatusText"/>
            <TextBox x:Name="ScanDaysText"/>
            <TextBox x:Name="AutomaticScanIntervalText"/>
            <TextBox x:Name="MaxItemsText"/>
            <TextBox x:Name="ReminderLookAheadText"/>
            <TextBox x:Name="DailyBoardTimeText"/>
            <TextBox x:Name="DailyBoardStartupDelayText"/>
            <TextBox x:Name="LlmTimeoutText"/>
            <TextBox x:Name="LlmApiKeyEnvText"/>
            <ComboBox x:Name="LlmFallbackPolicyBox">
                <ComboBoxItem Tag="LlmOnly" Content="검토 후보로 보관"/>
                <ComboBoxItem Tag="LlmThenRules" Content="규칙 기반 보조 허용"/>
            </ComboBox>
            <TextBox x:Name="DiagnosticsText"/>
            <ListBox x:Name="ReviewCandidatesList" MouseDoubleClick="OpenSelectedReviewMail_DoubleClick"/>
            <TextBlock x:Name="ReviewCandidatesEmptyText"/>
        </Grid>
    </Grid>
</Window>
