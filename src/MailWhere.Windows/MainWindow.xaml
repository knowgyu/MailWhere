<Window x:Class="MailWhere.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MailWhere" Height="680" Width="1040" MinHeight="620" MinWidth="940"
        Icon="Assets/app-icon.ico" Background="#F5F7FB"
        KeyDown="MainWindow_KeyDown">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,12,12"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,12,12"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#20304F"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="#F8FAFF"/>
            <Setter Property="BorderBrush" Value="#E8EDF7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Card" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#EEF3FF"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#2458F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="22" Background="#FFFFFF" Padding="18" Margin="0,0,0,14" BorderBrush="#E3E8F2" BorderThickness="1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="MailWhere" FontSize="24" FontWeight="Bold" Foreground="#14213D"/>
                    <TextBlock Text="최근 1개월 메일에서 Action item, 회의/일정, 마감 리마인드를 찾아 조용히 알려줍니다." Margin="0,5,0,0" Foreground="#5F6B83"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Click="RunDiagnostics_Click">진단 실행</Button>
                    <Button Click="OpenDailyBoard_Click">업무 보드</Button>
                    <Button x:Name="ScanRecentMonthButton" Click="ScanRecentMonth_Click" Background="#2458F2" Foreground="White">최근 1개월 스캔</Button>
                    <Button Click="TestNotification_Click">알림 테스트</Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="20" Background="#FFFFFF" Padding="16" Margin="0,0,14,0" BorderBrush="#E3E8F2" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="오늘 봐야 할 항목" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="StatusText" Text="대기 중입니다. 관리형 PC에서는 진단 후 최근 1개월 스캔부터 시작하세요." Foreground="#667085" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <ProgressBar x:Name="ScanProgressBar" Height="4" IsIndeterminate="True" Visibility="Collapsed" Margin="0,10,0,4"/>
                        <TextBlock x:Name="ScanProgressText" Text="대기 중입니다." Visibility="Collapsed" Foreground="#2458F2" FontWeight="SemiBold" FontSize="12"/>
                    </StackPanel>
                    <TabControl x:Name="MainTabs">
                        <TabItem x:Name="TasksTab" Header="할 일 / 일정">
                            <DockPanel Margin="8">
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <TextBlock Text="빠른 할 일 추가" FontWeight="SemiBold"/>
                                    <Grid Margin="0,6,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ManualTaskText" Grid.Column="0" MinHeight="34" ToolTip="예: 금요일까지 리뷰 자료 공유"/>
                                        <TextBox x:Name="ManualDueText" Grid.Column="1" MinHeight="34" ToolTip="예: 내일, 금요일, 2026-05-20" />
                                        <Button Grid.Column="2" Click="AddManualTask_Click" MinHeight="34">추가</Button>
                                    </Grid>
                                    <TextBlock Text="마감은 비워둘 수 있습니다. '내일', '금요일', '2026-05-20' 같은 표현을 우선 지원합니다." Foreground="#667085" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ListBox x:Name="TasksList" FontSize="14"/>
                            </DockPanel>
                        </TabItem>
                        <TabItem x:Name="ReviewTab" Header="검토함">
                            <DockPanel Margin="8">
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <TextBlock Text="확신이 낮아 자동 등록하지 않은 후보입니다. 메일 원문 없이 짧은 근거만 보여주며, 선택한 후보를 바로 할 일로 등록하거나 무시할 수 있습니다." TextWrapping="Wrap" Foreground="#667085" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Click="ApproveSelectedReview_Click" Background="#2458F2" Foreground="White">선택 항목 등록 (Alt+A)</Button>
                                        <Button Click="SnoozeSelectedReview_Click">나중에 보기 (Alt+S)</Button>
                                        <Button Click="IgnoreSelectedReview_Click">선택 항목 무시 (Alt+I)</Button>
                                    </StackPanel>
                                </StackPanel>
                                <ListBox x:Name="ReviewCandidatesList" FontSize="14"/>
                            </DockPanel>
                        </TabItem>
                        <TabItem Header="진단 로그">
                            <TextBox x:Name="DiagnosticsText" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas"/>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" CornerRadius="20" Background="#FFFFFF" Padding="16" BorderBrush="#E3E8F2" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="설정" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="LLM을 켜고 endpoint를 넣은 뒤 모델을 불러오세요." Foreground="#667085" TextWrapping="Wrap" Margin="0,4,0,14"/>

                        <CheckBox x:Name="StartupToggle" Content="Windows 시작 시 실행" Click="StartupToggle_Click" Margin="0,0,0,10"/>
                        <CheckBox x:Name="LlmEnabledToggle" Content="로컬 LLM 분석 사용" Margin="0,0,0,10"/>

                        <TextBlock Text="실행 방식" FontWeight="SemiBold"/>
                        <ComboBox x:Name="LlmProviderBox">
                            <ComboBoxItem Tag="Disabled" Content="사용 안 함 / rule-only"/>
                            <ComboBoxItem Tag="OllamaNative" Content="Ollama 로컬"/>
                            <ComboBoxItem Tag="OpenAiChatCompletions" Content="OpenAI 호환 - Chat Completions"/>
                            <ComboBoxItem Tag="OpenAiResponses" Content="OpenAI 호환 - Responses"/>
                        </ComboBox>

                        <TextBlock Text="로컬 endpoint" FontWeight="SemiBold"/>
                        <TextBox x:Name="LlmEndpointText" ToolTip="예: http://localhost:11434 또는 http://localhost:8000"/>
                        <TextBlock Text="모델" FontWeight="SemiBold"/>
                        <Grid Margin="0,4,12,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="LlmModelBox" Grid.Column="0" IsEditable="True" Margin="0" MinHeight="36" ToolTip="모델을 불러오거나 직접 입력하세요."/>
                            <Button x:Name="LoadLlmModelsButton" Grid.Column="1" Click="LoadLlmModels_Click" Margin="8,0,0,0" MinHeight="36">모델 불러오기</Button>
                        </Grid>

                        <TextBlock Text="LLM 실패 시" FontWeight="SemiBold"/>
                        <ComboBox x:Name="LlmFallbackPolicyBox">
                            <ComboBoxItem Tag="LlmOnly" Content="검토함에 남김 (기본)"/>
                            <ComboBoxItem Tag="LlmThenRules" Content="rule fallback 사용 (명시 선택)"/>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="TestLlmEndpointButton" Click="TestLlmEndpoint_Click" Background="#2458F2" Foreground="White">연결 테스트</Button>
                            <TextBlock x:Name="LlmStatusText" Text="LLM 연결 테스트 전입니다." VerticalAlignment="Center" Foreground="#667085" TextWrapping="Wrap"/>
                        </StackPanel>

                        <TextBlock Text="최근 스캔 기간(일)" FontWeight="SemiBold"/>
                        <TextBox x:Name="ScanDaysText"/>

                        <Button Click="SaveSettings_Click" HorizontalAlignment="Left" Background="#14213D" Foreground="White">설정 저장</Button>

                        <Expander Header="고급 설정" Margin="0,18,12,0">
                            <StackPanel Margin="0,10,0,0">
                                <CheckBox x:Name="AutoWatcherToggle" Content="자동 watcher 요청(운영 smoke gate 후 활성)" Margin="0,0,0,10"/>
                                <TextBlock Text="최대 메일 수(비우면 최근 기간 전체)" FontWeight="SemiBold"/>
                                <TextBox x:Name="MaxItemsText" ToolTip="문제 진단 때만 숫자를 넣으세요."/>
                                <TextBlock Text="알림 look-ahead(시간)" FontWeight="SemiBold"/>
                                <TextBox x:Name="ReminderLookAheadText"/>
                                <TextBlock Text="오늘의 업무 보드 시간" FontWeight="SemiBold"/>
                                <TextBox x:Name="DailyBoardTimeText" ToolTip="기본 08:00. 이 시간이 지난 뒤 앱이 켜지면 다음 정시에 한 번 표시합니다."/>
                                <TextBlock Text="Bearer token 환경 변수(선택)" FontWeight="SemiBold"/>
                                <TextBox x:Name="LlmApiKeyEnvText" ToolTip="예: LOCAL_LLM_TOKEN. 토큰 값 자체는 앱 설정에 저장하지 마세요."/>
                            </StackPanel>
                        </Expander>

                        <Border CornerRadius="14" Background="#F5F7FB" Padding="12" Margin="0,18,0,0">
                            <TextBlock Text="메일은 읽기만 합니다. 발송/삭제/이동/답장/첨부 자동 분석은 하지 않습니다." TextWrapping="Wrap" Foreground="#4C5874"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
